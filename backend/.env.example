# ── Server ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Site URL (used for email links, CORS, redirects) ────────────────
SITE_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# ── Email (SMTP) ─────────────────────────────────────────────────────
# For development: use Mailtrap, Ethereal, or similar
# For production: use SendGrid, Postmark, Mailgun, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DZIGN STORE <noreply@dzignstore.com>

# ── Notifications ────────────────────────────────────────────────────
# Where to send contact form notifications
NOTIFICATION_EMAIL=hello@dzignstore.com
