# DZIGN STORE — Environment Variables
# Copy this file to .env and fill in your values

# ── Site ──────────────────────────────────────────────────────────────
SITE_URL=https://your-domain.vercel.app

# ── Vercel Postgres ───────────────────────────────────────────────────
# Get this from Vercel Dashboard → Storage → your Postgres database
POSTGRES_URL="postgres://..."
POSTGRES_PRISMA_URL="postgres://...?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://..."

# ── SMTP (Email Notifications) ────────────────────────────────────────
# Use SendGrid, Postmark, Resend, Mailgun, or any SMTP provider
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=DZIGN STORE <noreply@yourdomain.com>
NOTIFICATION_EMAIL=hello@yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.vercel.app
